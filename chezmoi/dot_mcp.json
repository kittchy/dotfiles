{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ]
        },
        "memory": {
            "command": "bunx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        },
        "notion": {
            "serverUrl": "https://mcp.notion.com/mcp"
        },
        "fetch": {
            "command": "uvx",
            "args": [
                "mcp-server-fetch"
            ],
            "env": {},
            "disabled": false,
            "autoApprove": []
        }
    }
}
