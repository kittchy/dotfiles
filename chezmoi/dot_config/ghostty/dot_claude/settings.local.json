{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:cmux.com)",
      "WebFetch(domain:ghostty.org)",
      "WebFetch(domain:github.com)",
      "Bash(curl -s https://api.github.com/search/code?q=repo:ghostty-org/ghostty+filename:keybind+path:src/config)",
      "Bash(python3 -c \"import sys,json; data=json.load\\(sys.stdin\\); [print\\(i[''''path'''']\\) for i in data.get\\(''''items'''',[]\\)]\")",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(ghostty +list-keybinds)",
      "Bash(ghostty +list-actions)",
      "Bash(fc-list)"
    ]
  },
  "enabledMcpjsonServers": [
    "context7",
    "memory"
  ]
}
